---
/*
  /admin — the Fragment Manager (docs/admin.md §2). A flat, sortable table over
  ALL fragments (admin sees everything via RLS), rendered by the shared
  FragmentListPanel (also served as the fragments-panel partial to the
  composer's browser sheet). Filtering/sorting swap the table in place
  (fragment-panel.ts) — no full reload. Every fragment edits in an overlay:
  quotes/songs in the FragmentSheet, writing in the WritingSheet — the page
  underneath never navigates away.
*/
import { Icon } from 'astro-icon/components';
import AdminLayout from '../../layouts/AdminLayout.astro';
import FragmentListPanel from '../../components/admin/FragmentListPanel.astro';
import FragmentSheet from '../../components/admin/FragmentSheet.astro';
import WritingSheet from '../../components/admin/WritingSheet.astro';
import { parseListParams, queryFragmentList } from '../../lib/fragment-query';

const supabase = Astro.locals.supabase;
const params = parseListParams(Astro.url.searchParams);
params.constellation = null; // pick-mode concern; never used here
const data = await queryFragmentList(supabase, params);
const view = params.view;
const subjectNames = data.allSubjects.map((s) => s.name);
---

<AdminLayout title={view === 'trash' ? 'Trash' : 'Fragments'} active="fragments">
  <div class="mx-auto max-w-5xl px-6 py-8">
    <div class="flex items-baseline justify-between gap-4">
      <h1 class="font-display text-3xl font-light">{view === 'trash' ? 'Trash' : 'Fragments'}</h1>
      <div class="flex items-center gap-2">
        {
          view === 'trash' ? (
            <>
              <a href="/admin" class="btn btn-ghost btn-sm gap-1.5 font-sans">← Fragments</a>
              <button id="empty-trash" class="btn btn-outline btn-sm gap-1.5 font-sans text-error" disabled={data.rows.length === 0}>
                <Icon name="ph:trash" class="text-base" /> Empty trash
              </button>
            </>
          ) : (
            <>
              <a href="/admin?view=trash" class="btn btn-ghost btn-sm gap-1.5 font-sans">
                <Icon name="ph:trash" />
                Trash
                <span id="trash-count" class="rounded-full bg-base-300 px-1.5 text-xs text-base-content/70 empty:hidden">{data.trashCount || ''}</span>
              </a>
              <div class="relative">
                <button id="add-btn" class="btn btn-primary btn-sm gap-1 font-sans" aria-haspopup="menu" aria-expanded="false">
                  <Icon name="ph:plus" /> Add <span aria-hidden="true">▾</span>
                </button>
                <div id="add-menu" hidden role="menu" aria-label="Add a fragment" class="absolute right-0 z-30 mt-1 w-40 overflow-hidden rounded-box border border-base-300 bg-base-100 py-1 shadow-lg">
                  <button data-new-writing role="menuitem" class="add-item block w-full px-3 py-2 text-left text-sm"><span class="text-accent" aria-hidden="true">▤</span> Writing</button>
                  <button data-new="quote" role="menuitem" class="add-item block w-full px-3 py-2 text-left text-sm"><span class="text-secondary" aria-hidden="true">”</span> Quote</button>
                  <button data-new="song" role="menuitem" class="add-item block w-full px-3 py-2 text-left text-sm"><span class="text-primary" aria-hidden="true">♪</span> Song</button>
                </div>
              </div>
            </>
          )
        }
      </div>
    </div>

    <div class="mt-6">
      <FragmentListPanel data={data} params={params} mode="manage" />
    </div>
  </div>

  {/* Floating bulk-action bar (buttons rendered per view) */}
  <div id="bulkbar" class="bulkbar font-sans text-sm" data-view={view}>
    <span id="bulkcount" class="text-base-content/70">0 selected</span>
    <div class="flex gap-1">
      {
        view === 'trash' ? (
          <>
            <button data-bulk="restore" class="btn btn-xs btn-ghost normal-case">Restore</button>
            <button data-bulk="purge" class="btn btn-xs btn-ghost normal-case text-error">Delete forever</button>
          </>
        ) : (
          <>
            <button data-bulk="publish" class="btn btn-xs btn-ghost normal-case">Publish</button>
            <button data-bulk="unpublish" class="btn btn-xs btn-ghost normal-case">Unpublish</button>
            <button data-bulk="trash" class="btn btn-xs btn-ghost normal-case text-error">Delete</button>
          </>
        )
      }
    </div>
  </div>
  <p id="bulk-error" hidden role="alert" class="fixed bottom-20 left-1/2 z-40 -translate-x-1/2 rounded-field border border-error/40 bg-base-200 px-3 py-1.5 font-sans text-xs text-error shadow"></p>

  <FragmentSheet
    subjects={subjectNames}
    authors={data.allAuthors.map((a) => ({ id: a.id, name: a.name }))}
    works={data.allWorks.map((w) => ({ id: w.id, title: w.title, authorId: w.author_id }))}
  />
  <WritingSheet subjects={subjectNames} />

  <script>
    import '../../scripts/admin-list';
  </script>
</AdminLayout>
