---
/*
  /admin/writing/[id] — RETIRED as a page. The writing composer now lives in
  the WritingSheet overlay (docs/admin.md §5) so editing never navigates away
  from the list or the constellation composer. Old links still work: they land
  on the Fragment Manager with the sheet auto-opened via the hash.
*/
const { id } = Astro.params;
return Astro.redirect(!id || id === 'new' ? '/admin#new-writing' : `/admin#edit=${id}`);
---
