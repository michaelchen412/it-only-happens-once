---
/*
  PostCard — one essay in the blog feed (design.md §4, the Index).

  Adopts the constellation's reading surface (sky-lab round 2): the title + a
  faded, clamped excerpt form ONE reader trigger — click opens the in-context
  Reader (permalink is the no-JS fallback), and the pair warms toward lamplight
  on hover/focus. There's no "Read more" button: the fade + ellipsis is the
  invitation. Unlike the constellation, the blog KEEPS its metadata — date, read
  time, and subjects (left-aligned) sit quietly as chrome (§7).

  When a search term is active it switches to the occurrence view: the title
  highlights its matches (and still opens the Reader), and the body becomes
  bounded, windowed excerpts around each match (search-highlight.ts — same engine
  + rules as the admin, see docs/search.md). The reader <template> always carries
  the full, un-highlighted essay.
*/
import Timestamp from './Timestamp.astro';
import PostArticle from './PostArticle.astro';
import Highlighted from './admin/Highlighted.astro';
import { highlight, excerpts, toPlain, MIN_SEARCH } from '../lib/search-highlight';
import type { WritingItem } from '../lib/blog';

interface Props {
  item: WritingItem;
  /** The active search term, when searching — drives match highlighting. */
  term?: string;
}
const { item, term = '' } = Astro.props;

const searching = term.trim().length >= MIN_SEARCH;
const titleSegs = searching ? highlight(item.title, term) : null;
const { windows, more } = searching ? excerpts(toPlain(item.bodyMarkdown), term) : { windows: [], more: 0 };
const showWindows = searching && windows.length > 0;

// Subjects arrive busiest-first (lib/blog.ts). Show a few; the rest fold into a
// quiet "+N" so a heavily-tagged essay never overruns the footer.
const SUBJECT_CAP = 3;
const shownSubjects = item.subjects.slice(0, SUBJECT_CAP);
const extraSubjects = item.subjects.length - shownSubjects.length;
---

<article class="post-card py-9 first:pt-0">
  {/* The reading surface: title + excerpt warm together on hover/focus and open
      the Reader. The metadata sits inside so it warms with them, but stays its
      own (non-link) chrome. */}
  <div class="post-read">
    <h2 class="post-title font-display text-2xl leading-snug font-light sm:text-3xl">
      <a href={`/blog/${item.slug}`} data-read={item.slug}>
        {titleSegs ? <Highlighted segs={titleSegs} /> : item.title}
      </a>
    </h2>

    <div class="mt-3 flex flex-wrap items-center gap-3 text-sm text-base-content/40">
      <Timestamp date={item.occurredAt} updated={item.updatedAt ?? undefined} kind="posted" precision={item.precision} />
      <span class="font-sans">·</span>
      <span class="font-sans">{item.readMinutes} min read</span>
    </div>

    {
      showWindows ? (
        <div class="mt-4 space-y-1.5 font-serif leading-relaxed text-base-content/70">
          {windows.map((w) => (
            <p>
              {w.lead && '… '}
              <Highlighted segs={w.segs} />
              {w.trail && ' …'}
            </p>
          ))}
          {more > 0 && (
            <p class="font-sans text-xs text-base-content/40">
              +{more} more {more === 1 ? 'match' : 'matches'}
            </p>
          )}
        </div>
      ) : (
        <a href={`/blog/${item.slug}`} data-read={item.slug} class="mt-4 block cursor-pointer">
          <p
            class:list={[
              'post-excerpt font-serif leading-relaxed text-base-content/70',
              item.hasMore && 'post-excerpt-fade line-clamp-5',
            ]}
          >
            {item.excerpt}
          </p>
        </a>
      )
    }
  </div>

  {/* Subjects — left-aligned filter links, the quiet chrome at the foot (§7). */}
  {
    item.subjects.length > 0 && (
      <ul class="mt-4 flex flex-wrap items-center gap-x-3 gap-y-1 font-sans text-xs text-base-content/40">
        {shownSubjects.map((s) => (
          <li>
            <a href={`/blog?subject=${s.slug}`} class="transition-colors hover:text-base-content/70">
              {s.name}
            </a>
          </li>
        ))}
        {extraSubjects > 0 && <li class="text-base-content/30">+{extraSubjects}</li>}
      </ul>
    )
  }

  {/* Full essay, cloned into the Reader on demand. Inert until then. */}
  <template data-reader-content={item.slug}>
    <PostArticle item={item} linkTitle />
  </template>
</article>
