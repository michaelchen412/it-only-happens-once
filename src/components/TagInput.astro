---
/*
  TagInput — a proper tag/chip field (docs/admin.md §8). Type a subject and press
  Enter (or comma) to commit it as a chip; Backspace on the empty field removes
  the last; ✕ removes one. A hidden <input name> holds the comma-joined value, so
  it submits through Astro Actions exactly like a plain field. Native <datalist>
  autocompletes from existing subjects. Reused across the composer + quick-editors.

  `form` associates the hidden input with a form by id (needed when the field
  lives inside a <dialog> that is a sibling of the form). `.setTags(str)` lets a
  script repopulate it when opening an editor on an existing fragment.
*/
interface Props {
  name?: string;
  value?: string;
  suggestions?: string[];
  placeholder?: string;
  label?: string;
  form?: string;
  class?: string;
}
const {
  name = 'subjects',
  value = '',
  suggestions = [],
  placeholder = 'Add a subject…',
  label = 'Subjects',
  form,
  class: className = '',
} = Astro.props;
---

<tag-input
  class:list={['tag-input', className]}
  role="group"
  aria-label={label}
  data-name={name}
  data-value={value}
  data-placeholder={placeholder}
  data-form={form}
  data-suggest={JSON.stringify(suggestions)}
></tag-input>

<script>
  if (!customElements.get('tag-input')) {
    let uid = 0;
    class TagInput extends HTMLElement {
      tags: string[] = [];
      hiddenInput!: HTMLInputElement;
      field!: HTMLInputElement;
      live!: HTMLElement;

      connectedCallback() {
        const name = this.dataset.name || 'subjects';
        const placeholder = this.dataset.placeholder || '';
        const suggestions: string[] = JSON.parse(this.dataset.suggest || '[]');
        this.tags = this.parse(this.dataset.value || '');

        const listId = `tags-dl-${++uid}`;
        this.innerHTML = '';

        this.hiddenInput = document.createElement('input');
        this.hiddenInput.type = 'hidden';
        this.hiddenInput.name = name;
        if (this.dataset.form) this.hiddenInput.setAttribute('form', this.dataset.form);

        this.field = document.createElement('input');
        this.field.type = 'text';
        this.field.className = 'tag-input__field';
        this.field.placeholder = placeholder;
        this.field.setAttribute('list', listId);
        this.field.setAttribute('aria-label', this.getAttribute('aria-label') || 'Add a tag');
        this.field.autocomplete = 'off';

        const dl = document.createElement('datalist');
        dl.id = listId;
        for (const s of suggestions) {
          const opt = document.createElement('option');
          opt.value = s;
          dl.appendChild(opt);
        }

        this.live = document.createElement('span');
        this.live.className = 'sr-only';
        this.live.setAttribute('aria-live', 'polite');

        this.append(this.field, this.hiddenInput, dl, this.live);

        this.field.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ',') {
            e.preventDefault();
            this.add(this.field.value);
            this.field.value = '';
          } else if (e.key === 'Backspace' && this.field.value === '' && this.tags.length) {
            const removed = this.tags.pop();
            this.render();
            this.announce(`Removed ${removed}`);
          }
        });
        this.field.addEventListener('blur', () => {
          if (this.field.value.trim()) {
            this.add(this.field.value);
            this.field.value = '';
          }
        });
        this.addEventListener('mousedown', (e) => {
          if (e.target === this) {
            e.preventDefault();
            this.field.focus();
          }
        });

        this.render();
      }

      parse(raw: string): string[] {
        return raw
          .split(',')
          .map((s) => s.trim())
          .filter(Boolean);
      }

      /** Public: replace all tags (used when opening an editor on an existing row). */
      setTags(raw: string) {
        this.tags = this.parse(raw);
        this.render();
      }

      add(raw: string) {
        const t = raw.trim().replace(/,+$/, '').trim();
        if (!t) return;
        if (!this.tags.some((x) => x.toLowerCase() === t.toLowerCase())) {
          this.tags.push(t);
          this.announce(`Added ${t}`);
        }
        this.render();
      }

      announce(msg: string) {
        if (this.live) this.live.textContent = msg;
      }

      render() {
        this.querySelectorAll('.tag-input__chip').forEach((c) => c.remove());
        this.tags.forEach((tag, i) => {
          const chip = document.createElement('span');
          chip.className = 'tag-input__chip';
          chip.textContent = tag;
          const x = document.createElement('button');
          x.type = 'button';
          x.className = 'tag-input__x';
          x.setAttribute('aria-label', `Remove ${tag}`);
          x.textContent = '✕';
          x.addEventListener('click', () => {
            this.tags.splice(i, 1);
            this.render();
            this.announce(`Removed ${tag}`);
          });
          chip.appendChild(x);
          this.insertBefore(chip, this.field);
        });
        this.hiddenInput.value = this.tags.join(', ');
      }
    }
    customElements.define('tag-input', TagInput);
  }
</script>

<style is:global>
  .tag-input {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.375rem;
    min-height: 2.25rem;
    padding: 0.3rem 0.5rem;
    border: 1px solid var(--color-base-300);
    border-radius: var(--radius-field);
    background: var(--color-base-100);
    cursor: text;
  }
  .tag-input:focus-within {
    border-color: color-mix(in oklab, var(--color-primary) 60%, transparent);
  }
  .tag-input__chip {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.1rem 0.25rem 0.1rem 0.55rem;
    font-size: 0.8rem;
    line-height: 1.4;
    color: var(--color-base-content);
    background: var(--color-base-200);
    border: 1px solid var(--color-base-300);
    border-radius: 999px;
  }
  .tag-input__x {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1rem;
    height: 1rem;
    font-size: 0.65rem;
    color: var(--color-base-content);
    opacity: 0.45;
    border-radius: 999px;
  }
  .tag-input__x:hover {
    opacity: 1;
    color: var(--color-error);
  }
  .tag-input__field {
    flex: 1;
    min-width: 6rem;
    border: none;
    outline: none;
    background: transparent;
    color: var(--color-base-content);
    font-size: 0.875rem;
  }
</style>
