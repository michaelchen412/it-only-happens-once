---
/*
  QuoteCard — one quote in the blog feed. Quotes are short, so they render whole
  (no reader). When a search term is active, matches in the quote and its
  attribution highlight inline (search-highlight.ts — same engine as the essays;
  short fields use highlight(), not windowed excerpts, per docs/search.md).

  Layout notes (deliberate):
    · The quote is NOT italicized — a full italic block at this size reads as
      strained; upright serif is easier on the eyes. Set light, at reading
      size, with line breaks preserved (poetry survives).
    · The attribution is serif ALL-SMALL-CAPS in muted ink — the same
      convention the constellation suite uses (sky-lab round 1; Michael's
      call 2026-07-23: the blog follows the Sky here, not the reverse).
      Subjects + the date stay sans — they're chrome, not content.
    · The date is intentionally last, after the tags, and labelled "Added …":
      a quote's date is provenance (when it entered Michael's life), NOT when
      it was said — putting a bare date next to the attribution wrongly
      implies the latter.
*/
import Timestamp from './Timestamp.astro';
import Highlighted from './admin/Highlighted.astro';
import { MIN_SEARCH } from '../lib/search-highlight';
import type { QuoteItem } from '../lib/blog';

interface Props {
  item: QuoteItem;
  term?: string;
}
const { item, term = '' } = Astro.props;
const searching = term.trim().length >= MIN_SEARCH;

// Subjects arrive busiest-first (lib/blog.ts); cap to a few, fold the rest into
// a quiet "+N" so the caption stays on a tidy line or two.
const shownSubjects = item.subjects.slice(0, 3);
const extraSubjects = item.subjects.length - shownSubjects.length;
---

<figure class="py-9 first:pt-0">
  <blockquote class="font-serif text-[1.35rem] leading-[1.5] font-light whitespace-pre-line text-base-content">
    {searching ? <Highlighted text={item.body} term={term} /> : item.body}
  </blockquote>
  <figcaption class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-1 font-sans text-sm text-base-content/45">
    {
      item.attribution && (
        <span class="font-serif text-[1.05rem] tracking-[0.06em] text-base-content/50 [font-variant:all-small-caps]">
          — {searching ? <Highlighted text={item.attribution} term={term} /> : item.attribution}
        </span>
      )
    }
    {/* Subjects then the "Added" date, pinned right (provenance, not when-said). */}
    <div class="ml-auto flex flex-wrap items-center gap-x-3 gap-y-1">
      {item.subjects.length > 0 && (
        <ul class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-base-content/40">
          {shownSubjects.map((s) => (
            <li>
              <a href={`/blog?view=quotes&subject=${s.slug}`} class="transition-colors hover:text-base-content/70">
                {s.name}
              </a>
            </li>
          ))}
          {extraSubjects > 0 && <li class="text-base-content/30">+{extraSubjects}</li>}
        </ul>
      )}
      <Timestamp date={item.occurredAt} kind="added" precision={item.precision} prefix="Added" />
    </div>
  </figcaption>
</figure>
