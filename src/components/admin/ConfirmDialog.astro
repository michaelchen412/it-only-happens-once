---
/*
  ConfirmDialog — one styled confirmation modal for the whole admin, replacing
  native confirm(). Rendered once (in AdminLayout); driven by the promise-based
  helper in src/scripts/confirm-dialog.ts. Native <dialog> gives focus-trap,
  Escape, and focus restoration for free.
*/
---

<dialog id="confirm-dialog" class="modal-dialog w-full max-w-sm" aria-labelledby="confirm-title">
  <div class="flex flex-col gap-4 p-6 font-sans">
    <h2 id="confirm-title" class="font-display text-xl">Are you sure?</h2>
    <p id="confirm-message" class="text-sm text-base-content/70"></p>
    <div class="mt-1 flex justify-end gap-2">
      <button type="button" id="confirm-cancel" class="btn btn-ghost btn-sm normal-case">Cancel</button>
      <button type="button" id="confirm-ok" class="btn btn-primary btn-sm normal-case">Confirm</button>
    </div>
  </div>
</dialog>
