---
/*
  LinkDialog — the link editor for the rich text editor (replaces prompt()).
  Inner controls are class-scoped (not id) so more than one editor can coexist
  on a page; wired in src/scripts/rich-editor.ts. Pass `id` when a page has more
  than one editor, so each can target its own dialog.
*/
interface Props {
  id?: string;
}
const { id } = Astro.props;
---

<dialog id={id} class="link-dialog modal-dialog w-full max-w-sm" aria-label="Link">
  <div class="flex flex-col gap-4 p-6 font-sans">
    <h2 class="font-display text-xl">Link</h2>
    <input
      class="link-url input input-sm input-bordered"
      type="url"
      placeholder="https://…"
      aria-label="Link URL"
    />
    <div class="flex items-center justify-between">
      <button type="button" class="link-remove btn btn-ghost btn-sm text-error normal-case" hidden>Remove</button>
      <div class="ml-auto flex gap-2">
        <button type="button" class="link-cancel btn btn-ghost btn-sm normal-case">Cancel</button>
        <button type="button" class="link-apply btn btn-primary btn-sm normal-case">Apply</button>
      </div>
    </div>
  </div>
</dialog>
