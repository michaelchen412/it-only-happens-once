---
/*
  InterestRow — one editable {term, gloss} row in the About builder's interests
  repeater. Rendered both in the server-side list AND inside the clone <template>
  (with empty values), so the two can never drift. The up/down/remove controls
  are wired by event delegation in about-builder.ts.
*/
interface Props {
  term?: string;
  gloss?: string;
}
const { term = '', gloss = '' } = Astro.props;
const field =
  'rounded-field border border-base-300 bg-base-100 px-3 py-2 font-sans text-sm outline-none focus:border-primary/60';
---

<div class="interest-row flex items-start gap-2">
  <div class="grid flex-1 gap-2 sm:grid-cols-[10rem_1fr]">
    <input class:list={['interest-term', field]} placeholder="Jazz" value={term} />
    <input class:list={['interest-gloss', field]} placeholder="A short gloss" value={gloss} />
  </div>
  <div class="flex shrink-0 items-center gap-1 pt-1 font-sans text-base-content/45">
    <button type="button" class="interest-up rounded-field px-1.5 hover:bg-base-200 hover:text-base-content" aria-label="Move up">↑</button>
    <button type="button" class="interest-down rounded-field px-1.5 hover:bg-base-200 hover:text-base-content" aria-label="Move down">↓</button>
    <button type="button" class="interest-remove rounded-field px-1.5 hover:bg-base-200 hover:text-error" aria-label="Remove">✕</button>
  </div>
</div>
