---
/*
  SubjectFilter — a searchable, multi-select combobox for filtering the manager
  by subject. Selecting several subjects filters to fragments that have ALL of
  them (AND). A hidden <input name="subject"> holds the comma-joined slugs, and
  changes dispatch a bubbling `filter:change` event the list script listens for.
  The element definition lives in src/scripts/subject-filter.ts so fetched
  partials (the fragment browser) can rely on it too.
*/
interface Props {
  subjects: { name: string; slug: string }[];
  value?: string[]; // selected slugs
}
const { subjects, value = [] } = Astro.props;
---

<subject-filter
  class="subject-filter"
  data-options={JSON.stringify(subjects)}
  data-value={value.join(',')}
></subject-filter>

<script>
  import '../../scripts/subject-filter';
</script>
