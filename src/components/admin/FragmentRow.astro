---
/*
  One row of the Fragment Manager table (<tr>). The TITLE is the real, focusable
  control — an <a> (writing → composer, supports middle/⌘-click) or a <button>
  (quote/song → sheet). A click anywhere else on the row is a mouse-only
  convenience that triggers the same thing (src/scripts/admin-list.ts). In trash
  view the row isn't an edit target and shows Restore / Delete-forever actions.
*/
import type { Database } from '../../lib/database.types';
import { TYPE_META, shortDate, rowTitle, type FragmentType } from '../../lib/fragments-display';

type FragmentRowT = Database['public']['Tables']['fragments']['Row'];
interface Props {
  fragment: FragmentRowT;
  subjects: string[];
  view?: 'list' | 'trash';
}
const { fragment: r, subjects, view = 'list' } = Astro.props;
const meta = TYPE_META[r.type as FragmentType];
const trash = view === 'trash';

const editorData =
  r.type === 'writing'
    ? ''
    : JSON.stringify({
        id: r.id,
        type: r.type,
        title: r.title ?? '',
        body: r.body ?? '',
        attribution: r.attribution ?? '',
        source_url: r.source_url ?? '',
        status: r.status,
        year: new Date(r.occurred_at).getUTCFullYear(),
        subjects: subjects.join(', '),
        details: (r.details ?? {}) as Record<string, unknown>,
      });
---

<tr
  class:list={['fragment-row border-b border-base-300 last:border-0', !trash && 'hover:bg-base-200/40']}
  data-id={r.id}
  data-type={r.type}
  data-href={r.type === 'writing' ? `/admin/writing/${r.id}` : undefined}
  data-fragment={editorData || undefined}
>
  <td class="w-8 px-3 py-2.5 align-middle" data-noedit>
    <input type="checkbox" class="row-check checkbox checkbox-xs" value={r.id} aria-label={`Select ${rowTitle(r)}`} />
  </td>
  <td class:list={['w-6 text-center align-middle', meta.tone]}>
    <span aria-hidden="true">{meta.glyph}</span>
    <span class="sr-only">{meta.label}</span>
  </td>
  <td class="max-w-0 py-2.5 pr-3 align-middle">
    {
      trash ? (
        <div class="truncate">
          <span class:list={r.type === 'quote' ? 'italic' : ''}>{rowTitle(r)}</span>
        </div>
      ) : r.type === 'writing' ? (
        <a href={`/admin/writing/${r.id}`} class="row-open block truncate">{rowTitle(r)}</a>
      ) : (
        <button type="button" class:list={['row-open block max-w-full truncate text-left', r.type === 'quote' && 'italic']}>
          {rowTitle(r)}
        </button>
      )
    }
    {r.attribution && <div class="truncate font-sans text-xs text-base-content/60">{r.attribution}</div>}
  </td>
  <td class="hidden px-3 align-middle sm:table-cell">
    <span
      class:list={[
        'rounded-selector px-1.5 py-0.5 font-sans text-[0.65rem] tracking-wide uppercase',
        r.status === 'published' ? 'bg-primary/15 text-primary' : 'bg-base-300 text-base-content/70',
      ]}
    >
      {r.status}
    </span>
  </td>
  <td class="hidden px-3 text-right align-middle font-sans text-xs text-base-content/65 md:table-cell whitespace-nowrap">
    {shortDate(r.occurred_at)}
  </td>
  <td class="px-3 text-right align-middle font-sans text-xs text-base-content/65 whitespace-nowrap">
    {shortDate(r.updated_at)}
  </td>
  {
    trash && (
      <td class="px-3 text-right align-middle whitespace-nowrap" data-noedit>
        <button class="restore-btn font-sans text-xs text-base-content/70 hover:text-primary" data-id={r.id}>Restore</button>
        <button class="purge-btn ml-3 font-sans text-xs text-base-content/70 hover:text-error" data-id={r.id}>Delete</button>
      </td>
    )
  }
</tr>
