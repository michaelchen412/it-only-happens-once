---
import { Font } from 'astro:assets';
import '../styles/app.css';

interface Props {
  title?: string;
}

const { title = 'It Only Happens Once' } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dusk">
  <head>
    <meta charset="utf-8" />
    {/* Apply the saved theme before paint (no flash). Default stays dusk. */}
    <script is:inline>
      try {
        const t = localStorage.getItem('theme');
        if (t) document.documentElement.dataset.theme = t;
      } catch (e) {}
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <Font cssVariable="--font-newsreader" preload />
    <Font cssVariable="--font-atkinson" preload />
  </head>
  <body class="bg-base-100 text-base-content">
    <slot />
  </body>
</html>
