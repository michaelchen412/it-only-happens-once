---
/*
  AdminLayout — chrome for the third room (docs/admin.md §1).

  A private workshop, not a public surface: same dusk tokens, Atkinson chrome,
  but tuned for speed and density over poetry. Every /admin route is auth-gated
  by middleware and renders on demand (never cached, never public).
*/
import { Icon } from 'astro-icon/components';
import Base from './Base.astro';
import ConfirmDialog from '../components/admin/ConfirmDialog.astro';

interface Props {
  title?: string;
  /** Which top-nav item is active. */
  active?: 'fragments' | 'constellations' | 'library' | 'about';
}
const { title = 'Workshop', active = 'fragments' } = Astro.props;
const user = Astro.locals.user;

const nav = [
  { key: 'fragments', label: 'Fragments', href: '/admin', icon: 'ph:stack' },
  { key: 'constellations', label: 'Constellations', href: '/admin/constellations', icon: 'ph:moon-stars' },
  { key: 'library', label: 'Library', href: '/admin/library', icon: 'ph:books' },
  { key: 'about', label: 'About page', href: '/admin/about', icon: 'ph:user-circle' },
] as const;
---

<Base title={`${title} — Workshop`}>
  <div class="flex min-h-screen bg-base-100 font-sans">
    {/* Off-canvas backdrop (mobile only) */}
    <div
      id="sb-backdrop"
      class="pointer-events-none fixed inset-0 z-30 bg-black/50 opacity-0 transition-opacity duration-200 md:hidden"
    >
    </div>

    {/* Sidebar — fixed to the viewport on desktop (its own scroll + a pinned
        bottom block); an off-canvas drawer on mobile. */}
    <aside
      id="sidebar"
      class="fixed inset-y-0 left-0 z-40 flex w-60 -translate-x-full flex-col border-r border-base-300 bg-base-100 transition-transform duration-200 md:translate-x-0"
    >
      <div class="flex h-14 shrink-0 items-center gap-2 border-b border-base-300 px-4">
        <a href="/admin" class="flex items-baseline gap-2 whitespace-nowrap">
          <span class="font-display text-lg leading-none text-primary" aria-hidden="true">✦</span>
          <span class="font-display text-lg leading-none">Workshop</span>
        </a>
        <button id="sb-close" class="ml-auto rounded-field p-1 text-base-content/50 hover:bg-base-200 hover:text-base-content md:hidden" aria-label="Close menu">
          <Icon name="ph:x" class="text-lg" />
        </button>
      </div>

      <nav class="flex-1 space-y-1 overflow-y-auto overscroll-contain p-3">
        {
          nav.map((item) => (
            <a
              href={item.href}
              aria-current={active === item.key ? 'page' : undefined}
              class:list={[
                'flex items-center gap-3 rounded-field px-3 py-2 text-sm transition-colors',
                active === item.key
                  ? 'bg-base-200 font-medium text-base-content'
                  : 'text-base-content/60 hover:bg-base-200/60 hover:text-base-content',
              ]}
            >
              <Icon name={item.icon} class="text-lg" />
              {item.label}
            </a>
          ))
        }
      </nav>

      <div class="shrink-0 space-y-2 border-t border-base-300 p-3">
        <div class="truncate px-1 text-xs text-base-content/40" title={user?.email}>{user?.email}</div>
        <div class="flex items-center gap-1 text-xs text-base-content/50">
          <button
            id="theme-toggle"
            class="theme-toggle rounded-field p-1.5 hover:bg-base-200 hover:text-base-content"
            aria-label="Toggle light and dark theme"
            title="Toggle theme"
          >
            <Icon name="ph:sun" class="theme-icon-sun text-base" />
            <Icon name="ph:moon" class="theme-icon-moon text-base" />
          </button>
          <a href="/" class="rounded-field px-2 py-1 hover:bg-base-200 hover:text-base-content" title="View the site">Site ↗</a>
          <button id="admin-signout" class="ml-auto rounded-field px-2 py-1 hover:bg-base-200 hover:text-base-content">Sign out</button>
        </div>
      </div>
    </aside>

    {/* Main column — padded left of the fixed sidebar on desktop. */}
    <div class="flex min-w-0 flex-1 flex-col md:pl-60">
      {/* Slim top bar — mobile only (desktop uses the full height for content) */}
      <header class="sticky top-0 z-20 flex h-14 shrink-0 items-center gap-3 border-b border-base-300 bg-base-100/90 px-4 backdrop-blur md:hidden">
        <button id="sb-open" class="-ml-1 rounded-field p-1.5 text-base-content/70 hover:bg-base-200 hover:text-base-content" aria-label="Open menu" aria-controls="sidebar" aria-expanded="false">
          <Icon name="ph:list" class="text-xl" />
        </button>
        <span class="font-display text-lg leading-none text-primary" aria-hidden="true">✦</span>
        <span class="font-display text-base leading-none">{title}</span>
      </header>

      <main class="min-w-0 flex-1">
        <slot />
      </main>
    </div>
  </div>

  <ConfirmDialog />

  <script>
    import { createBrowserClient } from '@supabase/ssr';
    const supabase = createBrowserClient(
      import.meta.env.PUBLIC_SUPABASE_URL,
      import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
    );
    document.getElementById('admin-signout')?.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = '/';
    });

    // --- mobile off-canvas sidebar ---
    const sidebar = document.getElementById('sidebar');
    const backdrop = document.getElementById('sb-backdrop');
    const openBtn = document.getElementById('sb-open');
    const openSidebar = () => {
      sidebar?.classList.remove('-translate-x-full');
      backdrop?.classList.remove('opacity-0', 'pointer-events-none');
      openBtn?.setAttribute('aria-expanded', 'true');
    };
    const closeSidebar = () => {
      sidebar?.classList.add('-translate-x-full');
      backdrop?.classList.add('opacity-0', 'pointer-events-none');
      openBtn?.setAttribute('aria-expanded', 'false');
    };
    openBtn?.addEventListener('click', openSidebar);
    document.getElementById('sb-close')?.addEventListener('click', closeSidebar);
    backdrop?.addEventListener('click', closeSidebar);
    document.addEventListener('keydown', (e) => e.key === 'Escape' && closeSidebar());

    const themeBtn = document.getElementById('theme-toggle');
    const syncThemeBtn = () => themeBtn?.setAttribute('aria-pressed', String(document.documentElement.dataset.theme === 'paper'));
    syncThemeBtn();
    themeBtn?.addEventListener('click', () => {
      const next = document.documentElement.dataset.theme === 'paper' ? 'dusk' : 'paper';
      document.documentElement.dataset.theme = next;
      try {
        localStorage.setItem('theme', next);
      } catch (e) {}
      syncThemeBtn();
    });
    // keep other open tabs in sync
    window.addEventListener('storage', (e) => {
      if (e.key === 'theme' && e.newValue) {
        document.documentElement.dataset.theme = e.newValue;
        syncThemeBtn();
      }
    });
  </script>
</Base>
