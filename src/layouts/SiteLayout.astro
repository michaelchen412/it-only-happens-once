---
/*
  SiteLayout — chrome for the PUBLIC site (the reader-facing rooms).

  Distinct from AdminLayout (the private workshop). This is the editorial
  register from design.md §8: a quiet top bar with a plain wordmark, generous
  space, no ornament. Wraps Base.astro (which owns <head>, fonts, the no-flash
  theme script). Pages opt into an `active` nav item.

  Note: the brand links home (`/`), which now carries the public chrome. The
  Sky itself (landing in a constellation, the zoom) is a later design pass.
*/
import { Icon } from 'astro-icon/components';
import Base from './Base.astro';

interface Props {
  title?: string;
  /** Which top-nav item is highlighted. */
  active?: 'blog' | 'about';
}
const { title, active } = Astro.props;
const pageTitle = title ? `${title} — It Only Happens Once` : 'It Only Happens Once';

const nav = [
  { key: 'blog', label: 'Blog', href: '/blog' },
  { key: 'about', label: 'About', href: '/about' },
] as const;
---

<Base title={pageTitle}>
  <div class="flex min-h-screen flex-col">
    {/* Top bar — the site's primary navigation. */}
    <header
      class="sticky top-0 z-20 flex h-14 items-center gap-4 border-b border-base-300 bg-base-100/90 px-5 backdrop-blur"
    >
      <a
        href="/"
        class="font-display text-base leading-none whitespace-nowrap sm:text-lg"
        aria-label="It Only Happens Once — home"
      >
        It Only Happens Once
      </a>

      <nav class="ml-auto flex items-center gap-4 sm:gap-5" aria-label="Primary">
        {
          nav.map((item) => (
            <a
              href={item.href}
              aria-current={active === item.key ? 'page' : undefined}
              class:list={[
                'font-sans text-sm transition-colors',
                active === item.key
                  ? 'border-b border-primary pb-0.5 text-base-content'
                  : 'text-base-content/60 hover:text-base-content',
              ]}
            >
              {item.label}
            </a>
          ))
        }
        <button
          id="theme-toggle"
          class="theme-toggle rounded-field p-1.5 text-base-content/55 hover:bg-base-200 hover:text-base-content"
          aria-label="Toggle light and dark theme"
          title="Toggle theme"
        >
          <Icon name="ph:sun" class="theme-icon-sun text-base" />
          <Icon name="ph:moon" class="theme-icon-moon text-base" />
        </button>
      </nav>
    </header>

    <main class="min-w-0 flex-1">
      <slot />
    </main>

    <footer class="border-t border-base-300 px-5 py-6">
      <div class="mx-auto max-w-3xl font-sans text-xs text-base-content/40">It Only Happens Once</div>
    </footer>
  </div>

  <script>
    // Theme toggle — dusk ⇄ paper, persisted (mirrors AdminLayout).
    const themeBtn = document.getElementById('theme-toggle');
    const syncThemeBtn = () =>
      themeBtn?.setAttribute('aria-pressed', String(document.documentElement.dataset.theme === 'paper'));
    syncThemeBtn();
    themeBtn?.addEventListener('click', () => {
      const next = document.documentElement.dataset.theme === 'paper' ? 'dusk' : 'paper';
      document.documentElement.dataset.theme = next;
      try {
        localStorage.setItem('theme', next);
      } catch (e) {}
      syncThemeBtn();
    });
    // keep other open tabs in sync
    window.addEventListener('storage', (e) => {
      if (e.key === 'theme' && e.newValue) {
        document.documentElement.dataset.theme = e.newValue;
        syncThemeBtn();
      }
    });
  </script>
</Base>
