# Copy this file to `.env.local` and fill in the values.
# `.env.local` is git-ignored; this template is committed so the required
# variables are documented (anti-drift). See docs/auth.md §Secrets.
#
# Rule: only PUBLIC_* variables may be referenced from client-side code.
#       Everything else is server-only and must never reach the browser.

# --- Supabase ---------------------------------------------------------------
PUBLIC_SUPABASE_URL="https://deodwnoztppvtrnehwzg.supabase.co"
# Publishable/anon key — safe in the browser; RLS restricts it to published rows.
PUBLIC_SUPABASE_ANON_KEY="sb_publishable_xxxxxxxx"
# SERVER ONLY. Bypasses RLS. Used only in trusted server scripts (e.g. seeds).
# Supabase dashboard → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=""

# --- Auth ------------------------------------------------------------------
# Auth is Supabase Auth (Google OAuth + passkeys). No extra keys needed: the
# Google client ID/secret are configured in the Supabase dashboard, and auth
# uses the PUBLIC_SUPABASE_* values above. See docs/auth.md.
