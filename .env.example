# Copy this file to `.env.local` and fill in the values.
# `.env.local` is git-ignored; this template is committed so the required
# variables are documented (anti-drift). See docs/auth.md §Secrets.
#
# Rule: only PUBLIC_* variables may be referenced from client-side code.
#       Everything else is server-only and must never reach the browser.

# --- Supabase ---------------------------------------------------------------
PUBLIC_SUPABASE_URL="https://deodwnoztppvtrnehwzg.supabase.co"
# Publishable/anon key — safe in the browser; RLS restricts it to published rows.
PUBLIC_SUPABASE_ANON_KEY="sb_publishable_xxxxxxxx"
# SERVER ONLY. Bypasses RLS. Used only in trusted server scripts (e.g. seeds).
# Supabase dashboard → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=""

# --- Auth ------------------------------------------------------------------
# Auth is Supabase Auth (Google OAuth + passkeys). No extra keys needed: the
# Google client ID/secret are configured in the Supabase dashboard, and auth
# uses the PUBLIC_SUPABASE_* values above. See docs/auth.md.

# --- AI ---------------------------------------------------------------------
# SERVER ONLY. Powers the admin "Suggest subjects" button (Claude Haiku 4.5).
# Absent = the button degrades gracefully (manual tagging still works).
# console.anthropic.com → API keys.
ANTHROPIC_API_KEY=""

# --- Contact form -----------------------------------------------------------
# The public /about "Say hello" form: email delivery via Resend, spam-guarded
# by Cloudflare Turnstile. If these are absent the form still renders, but
# submitting returns "not configured yet" (and Turnstile is skipped in dev).

# SERVER ONLY. resend.com → API Keys.
RESEND_API_KEY=""
# Where messages are delivered (your inbox).
CONTACT_TO_EMAIL="you@example.com"
# Optional From address — must be on a domain verified in Resend. Defaults to
# Resend's shared onboarding@resend.dev (fine for a first end-to-end test).
CONTACT_FROM_EMAIL=""

# Cloudflare Turnstile (dash.cloudflare.com → Turnstile). The site key is PUBLIC
# (embedded in the widget); the secret key is SERVER ONLY.
PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
